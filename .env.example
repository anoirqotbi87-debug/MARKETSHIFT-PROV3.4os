# MarketShift Pro v3.4os - Configuration Environnement
# ============================================================
# IMPORTANT: Copiez ce fichier vers .env.local et remplissez les valeurs
# WARNING: Ne JAMAIS commiter le fichier .env* dans Git
# ============================================================

# ============================================================
# CLÉ DE CHIFFREMENT (OBLIGATOIRE)
# ============================================================
# Générez une clé sécurisée avec: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TRADINGBOT_ENCRYPTION_KEY=<your-secure-encryption-key-here>

# ============================================================
# DASHBOARD CONFIGURATION (OBLIGATOIRE)
# ============================================================
DASHBOARD_USER=<your-dashboard-username>
DASHBOARD_PASS=<your-secure-dashboard-password>

# ============================================================
# EXNESS CONFIGURATION
# ============================================================
EXNESS_ENABLED=false
EXNESS_LOGIN=<your-exness-login-number>
EXNESS_PASSWORD=<your-exness-password>
EXNESS_SERVER=<exness-server-name>

# ============================================================
# XM CONFIGURATION
# ============================================================
XM_ENABLED=true
XM_LOGIN=<your-xm-login-number>
XM_PASSWORD=<your-xm-password>
XM_SERVER=<xm-server-name>

# ============================================================
# BROKER ACTIF (exness ou xm)
# ============================================================
ACTIVE_BROKER=xm

# ============================================================
# PARAMÈTRES DU BOT
# ============================================================
SIMULATION_MODE=false
MAX_DAILY_LOSS=0.05

# ============================================================
# GOOGLE GEMINI API (OBLIGATOIRE)
# ============================================================
# Obtenez une clé gratuite sur: https://ai.google.dev/
GEMINI_API_KEY=<your-gemini-api-key>

# ============================================================
# FIREBASE CONFIGURATION (OBLIGATOIRE)
# ============================================================
# Récupérez ces valeurs depuis votre console Firebase
REACT_APP_FIREBASE_PROJECT_ID=<your-firebase-project-id>
REACT_APP_FIREBASE_API_KEY=<your-firebase-api-key>
REACT_APP_FIREBASE_AUTH_DOMAIN=<your-firebase-auth-domain>
REACT_APP_FIREBASE_DATABASE_URL=<your-firebase-database-url>
REACT_APP_FIREBASE_STORAGE_BUCKET=<your-firebase-storage-bucket>
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=<your-firebase-messaging-sender-id>
REACT_APP_FIREBASE_APP_ID=<your-firebase-app-id>
REACT_APP_FIREBASE_MEASUREMENT_ID=<your-firebase-measurement-id>

# ============================================================
# ALPHA VANTAGE API (News Filter)
# ============================================================
# Obtenez une clé gratuite sur: https://www.alphavantage.co/support#api-key
# Free tier: 5 appels/minute, 500 appels/jour
ALPHA_VANTAGE_API_KEY=<your-alpha-vantage-api-key>

# ============================================================
# TELEGRAM CONFIGURATION (OPTIONNEL)
# ============================================================
# Telegram bot token from @BotFather
# Format: <bot-id>:<bot-token>
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# Comma-separated Telegram user IDs allowed to send commands
# Format: 123456789,987654321
# Leave empty to allow anyone (not recommended for production)
ADMIN_TELEGRAM_IDS=<comma-separated-user-ids>

# ============================================================
# NEWS FILTER
# ============================================================
# Activer le filtre de news (true/false)
NEWS_FILTER_ENABLED=true

# ============================================================
# SERVER CONFIGURATION
# ============================================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
